# Copy this file to .env at the project root and fill in values.
# Shared by all three sub-projects: agents/ · api/ · ui/

# ── AI ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Primary model: Claude Sonnet 4.6
OPENAI_API_KEY=sk-proj-...            # Fallback model: GPT-4o
GEMINI_API_KEY=AIza...                # Second fallback: Gemini

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── NestJS API ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
API_PORT=3000

# ── Vue UI (VITE_ prefix exposes vars to the browser) ────────────────────────
VITE_API_URL=http://localhost:3000/api

# ── HuggingFace Deployment ───────────────────────────────────────────────────
HF_SPACE_URL=https://huggingface.co/spaces/<username>/<space-name>
HF_TOKEN=hf_...

# ── GitHub (artifacts + workflow dispatch) ───────────────────────────────────
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=<owner>/<repo>
ARTIFACTS_PATH=https://github.com/<owner>/<artifacts-repo>/<prefix>
